{
  "name": "calendar-task-manager",
  "version": "1.0.0",
  "description": "Lightweight Electron Calendar Task Manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder --win",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.tododo.app",
    "productName": "Tododo",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Tododo"
    }
  },
  "keywords": [
    "electron",
    "calendar",
    "task",
    "manager"
  ],
  "author": "eben",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
